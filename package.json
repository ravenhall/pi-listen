{
  "name": "pi-listen",
  "version": "0.1.0",
  "description": "Local speech-to-text listener extension for Pi Coding Agent",
  "type": "module",
  "keywords": [
    "pi-package",
    "speech-to-text",
    "whisper",
    "voice"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "files": [
    "bin",
    "dist",
    "lib",
    "src",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "check": "node --check dist/index.js && perl -Ilib -c bin/pi-listen-bridge.pl && prove -Ilib t && node script/smoke-package.mjs",
    "test:perl": "prove -Ilib t",
    "smoke:package": "node script/smoke-package.mjs",
    "coverage:perl": "perl script/run-perl-coverage.pl 80"
  }
}
